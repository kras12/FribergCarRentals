@using FribergCarRentals.Controllers.Admin
@using MvcRazorPages.Shared.ViewModels.Car
@using MvcRazorPages.Shared.ViewModels.CarCategory
@using MvcRazorPages.Shared.ViewModels.Other
@model ListViewModel<CarCategoryViewModel>

@{
    ViewData["Title"] = "List";
}

<h1>Categories</h1>
<div class="vertical-flex-container flex-container__row-gap__1-rem flex-container__align-items-center">
    @if (Model.Count <= 0)
    {
        <p class="text-align-center">No categories found.</p>
    }
    <div class="horizontal-flex-container flex-container__justify-content__center flex-container__column-gap__0-5-rem">
        <a asp-action="Create" class="button function-button">Create Category</a>
    </div>
    <partial name="/Views/Shared/_UserMessages.cshtml" for="Messages" />
    @if (Model.Count > 0)
    {
        <table class="slim-table colored-table">
            <thead>
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => Model.Models[0].CategoryId)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => Model.Models[0].CategoryName)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => Model.Models[0].CarCount)
                    </th>
                    <th>
                        Actions
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Models)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.CategoryId)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.CategoryName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.CarCount)
                        </td>
                        <td>
                            <div class="horizontal-flex-container flex-container__column-gap__0-5-rem">
                                <a asp-action="Details" asp-route-id="@item.CategoryId" class="button navigational-button">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.CategoryId" class="button function-button">Edit</a>       
                                @if (item.HaveCarCount && item.CarCount == 0)
                                {
                                    <form asp-action="Delete" onsubmit="return confirm('Are you sure you want to delete this car?');">
                                        <input type="hidden" name="id" value="@item.CategoryId" asp-for="@item.CategoryId" />
                                        <button type="submit" class="negative-button">Delete</button>
                                    </form>
                                }                            
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>