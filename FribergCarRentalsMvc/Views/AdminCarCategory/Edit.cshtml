@using FribergCarRentals.Controllers.Admin
@using FribergCarRentals.Data.Types
@using FribergCarRentals.Data.EntityClasses
@using AppSettings.Shared.Settings;
@using FribergCarRentals.Data.Attributes
@using FribergCarRentals.Data.Extensions
@using MvcRazorPages.Shared.ViewModels.CarCategory
@model EditCarCategoryViewModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>
@if (Model.HavePageSubTitle)
{
    <h2>@Model.PageSubTitle</h2>
}
else
{
    <h2>@($"#{Model.CarCategoryId} - {Model.CategoryName}")</h2>
}
<div class="vertical-flex-container flex-container__align-items-center flex-container__row-gap__1-rem">
    <div class="horizontal-flex-container flex-container__justify-content__center flex-container__column-gap__0-5-rem">
        <a asp-action="List" class="button navigational-button">View Categories</a>
        <form asp-action="Delete" onsubmit="return confirm('Are you sure you want to delete this category?');">
            <input type="hidden" name="id" value="@Model.CarCategoryId" asp-for="CarCategoryId" />
            <button type="submit" class="negative-button">Delete</button>
        </form>
    </div>
    <partial name="/Views/Shared/_UserMessages.cshtml" for="Messages" />
    <div class="vertical-flex-container flex-container__align-items-center flex-container__row-gap__0-5-rem filled-container flex-container__padding__1-rem full-width">
        <h2>Details</h2>
        <form asp-action="Edit" class="vertical-form full-width" enctype="multipart/form-data">
            <input type="hidden" asp-for="CarCategoryId" />
            <div class="vertical-form-field">
                <div asp-validation-summary="ModelOnly" class="error-text"></div>
            </div>           
            <div class="vertical-form-field">
                <label asp-for="CategoryName"></label>
                <input asp-for="CategoryName" />
                <span asp-validation-for="CategoryName" class="error-text"></span>
            </div>            
            <div class="vertical-form-field">
                <button type="submit">Save</button>
            </div>
        </form>
    </div>
</div>


@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
