@page
@model FribergCarRentals.Pages.Admin.Customer.ListModel

@{
    ViewData["Title"] = "List";
}

<h1>Customers</h1>
<div class="vertical-flex-container flex-container__row-gap__1-rem">
    @if (Model.CustomerListViewModel.Count <= 0)
    {
        <p class="text-align-center no-margin">No customers found.</p>
    }
    <div class="horizontal-flex-container flex-container__justify-content__center flex-container__column-gap__0-5-rem">
        <a asp-page="Create" class="button function-button">Create Customer</a>
    </div>
    <partial name="/Pages/Shared/_UserMessages.cshtml" for="CustomerListViewModel.Messages" />
    @if (Model.CustomerListViewModel.Count > 0)
    {
        <table class="colored-table">
            <thead>
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.CustomerListViewModel.Models[0].CustomerId)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.CustomerListViewModel.Models[0].FirstName)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.CustomerListViewModel.Models[0].LastName)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.CustomerListViewModel.Models[0].Email)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.CustomerListViewModel.Models[0].OrderCount)
                    </th>
                    <th>
                        Actions
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.CustomerListViewModel.Models)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.CustomerId)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.FirstName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.LastName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Email)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.OrderCount)
                        </td>
                        <td>
                            <div class="horizontal-flex-container flex-container__column-gap__0-5-rem">
                                <a asp-page="Details" asp-route-id="@item.CustomerId" class="button navigational-button">Details</a>
                                <a asp-page="Edit" asp-route-id="@item.CustomerId" class="button function-button">Edit</a>
                                <form asp-page="Delete" onsubmit="return confirm('Are you sure you want to delete this customer?');">
                                    <input type="hidden" name="id" value="@item.CustomerId" asp-for="@item.CustomerId" />
                                    <button type="submit" class="negative-button">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
