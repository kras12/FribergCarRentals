@page "{id}"
@using FribergCarRentals.DataAccess.Types
@using FribergCarRentals.DataAccess.EntityClasses
@using FribergCarRentals.Data.SharedClasses
@using FribergCarRentals.DataAccess.Attributes
@using FribergCarRentals.DataAccess.Extensions
@using FribergCarRentals.Models.Car
@model FribergCarRentals.Pages.Admin.CarCategories.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>
@if (Model.EditCarCategoryViewModel.HavePageSubTitle)
{
    <h2>@Model.EditCarCategoryViewModel.PageSubTitle</h2>
}
else
{
    <h2>@($"#{Model.EditCarCategoryViewModel.CarCategoryId} - {Model.EditCarCategoryViewModel.CategoryName}")</h2>
}
<div class="vertical-flex-container flex-container__align-items-center flex-container__row-gap__1-rem">
    <div class="horizontal-flex-container flex-container__justify-content__center flex-container__column-gap__0-5-rem">
        <a asp-page="List" class="button navigational-button">View Categories</a>
        <form asp-page="Delete" onsubmit="return confirm('Are you sure you want to delete this category?');">
            <input type="hidden" name="id" value="@Model.EditCarCategoryViewModel.CarCategoryId" asp-for="EditCarCategoryViewModel.CarCategoryId" />
            <button type="submit" class="negative-button">Delete</button>
        </form>
    </div>
    <partial name="/Pages/Shared/_UserMessages.cshtml" for="EditCarCategoryViewModel.Messages" />
    <div class="vertical-flex-container flex-container__align-items-center flex-container__row-gap__0-5-rem filled-container flex-container__padding__1-rem full-width">
        <h2>Details</h2>
        <form asp-page="Edit" class="vertical-form full-width" enctype="multipart/form-data">
            <input type="hidden" asp-for="EditCarCategoryViewModel.CarCategoryId" />
            <div class="vertical-form-field">
                <div asp-validation-summary="ModelOnly" class="error-text"></div>
            </div>
            <div class="vertical-form-field">
                <label asp-for="EditCarCategoryViewModel.CategoryName"></label>
                <input asp-for="EditCarCategoryViewModel.CategoryName" />
                <span asp-validation-for="EditCarCategoryViewModel.CategoryName" class="error-text"></span>
            </div>
            <div class="vertical-form-field">
                <button type="submit">Save</button>
            </div>
        </form>
    </div>
</div>


@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
