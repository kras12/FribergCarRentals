@using FribergCarRentals.Areas.Admin.Pages
@using FribergCarRentals.Shared.Constants
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService

@if ((await AuthorizationService.AuthorizeAsync(User, ApplicationUserPolicies.Admin)).Succeeded)
{
    @if ((string)ViewContext.RouteData.Values["area"]! == AdminPageModelBase.Area)
    {
        <li>
            <a asp-area="@AdminPageModelBase.Area" asp-page="/Index">Home</a>
        </li>
        <li>
            <a asp-area="@AdminPageModelBase.Area" asp-page="/Car/Category/List">Car Categories</a>
        </li>
        <li>
            <a asp-area="@AdminPageModelBase.Area" asp-page="/Car/List">Cars</a>
        </li>
        <li>
            <a asp-area="@AdminPageModelBase.Area" asp-page="/Customer/List">Customers</a>
        </li>
        <li>
            <a asp-area="@AdminPageModelBase.Area" asp-page="/Order/List">Orders</a>
        </li>
    }
    else
    {
        <partial name="_CustomerMenuItems.cshtml" />
    }

    <div class="menu-group right-aligned">
        @if ((string)ViewContext.RouteData.Values["area"]! != AdminPageModelBase.Area)
        {
            <li>
                <a asp-area="@AdminPageModelBase.Area" asp-page="Index">Account</a>
            </li>
        }
        <li>
            <a asp-area="@AdminPageModelBase.Area" asp-page="/Logout">Logout</a>
        </li>
    </div>
}