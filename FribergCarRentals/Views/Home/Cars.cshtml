@using FribergCarRentals.Models.Car
@using FribergCarRentals.Models.Other
@model ListViewModel<CarViewModel>

@{
    ViewData["Title"] = "Cars";
}

<h1>Available cars</h1>
<div class="vertical-flex-container flex-container__row-gap__2-rem">
    @if (Model.Count > 0)
    {
        @foreach (var item in Model.Models)
        {
            <div id="@item.CarId" class="vertical-flex-container filled-container flex-container__padding__1-rem flex-container__row-gap__1-rem">
                <h2>@($"{item.CarInfo}")</h2>
                <div class="horizontal-flex-container flex-container__justify-content__center flex-container__column-gap__0-5-rem">
                    <form asp-action="Book" asp-controller="CustomerOrder" asp-route-carId="@item.CarId" method="get">
                        <button class="function-button" type="submit">Book Car</button>
                    </form>
                </div>
                <dl>
                    <dt>
                        @Html.DisplayNameFor(model => item.Brand)
                    </dt>
                    <dd>
                        @Html.DisplayFor(model => item.Brand)
                    </dd>
                    <dt>
                        @Html.DisplayNameFor(model => item.Model)
                    </dt>
                    <dd>
                        @Html.DisplayFor(model => item.Model)
                    </dd>
                    <dt>
                        @Html.DisplayNameFor(model => item.ModelYear)
                    </dt>
                    <dd>
                        @Html.DisplayFor(model => item.ModelYear)
                    </dd>
                    <dt>
                        @Html.DisplayNameFor(model => item.Color)
                    </dt>
                    <dd>
                        @Html.DisplayFor(model => item.Color)
                    </dd>
                    <dt>
                        @Html.DisplayNameFor(model => item.PropulsionSystem)
                    </dt>
                    <dd>
                        @item.PropulsionSystem.PropulsionName
                    </dd>
                </dl>
                <div class="tiled-image-gallery">
                    @foreach (var image in item.Images)
                    {
                        <figure>
                            <div class="vertical-flex-container">
                                <img src="@image.Url" />
                            </div>
                        </figure>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-align-center">Currently there are no cars available to rent.</p>
    }
</div>
