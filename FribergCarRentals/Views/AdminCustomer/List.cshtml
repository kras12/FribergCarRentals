@using FribergCarRentals.Models.Customer
@using FribergCarRentals.Models.Other
@model ListViewModel<CustomerViewModel>

@{
    ViewData["Title"] = "List";
}

<h1>Customers</h1>
<div class="vertical-flex-container flex-container__row-gap__1-rem">
    @if (Model.Count <= 0)
    {
        <p class="text-align-center no-margin">No customers found.</p>
    }
    <div class="horizontal-flex-container flex-container__justify-content__center flex-container__column-gap__0-5-rem">
        <a asp-action="Create" class="button function-button">Create Customer</a>
    </div>
    <partial name="/Views/Shared/_UserMessages.cshtml" for="Messages" />
    @if (Model.Count > 0)
    {
        <table class="colored-table">
            <thead>
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.Models[0].UserId)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Models[0].FirstName)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Models[0].LastName)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Models[0].Email)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Models[0].OrderCount)
                    </th>
                    <th>
                        Actions
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Models)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.UserId)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.FirstName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.LastName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Email)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.OrderCount)
                        </td>
                        <td>
                            <div class="horizontal-flex-container flex-container__column-gap__0-5-rem">
                                <a asp-action="Details" asp-route-id="@item.UserId" class="button navigational-button">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.UserId" class="button function-button">Edit</a>
                                <form asp-action="Delete" onsubmit="return confirm('Are you sure you want to delete this customer?');">
                                    <input type="hidden" name="id" value="@item.UserId" asp-for="@item.UserId" />
                                    <button type="submit" class="negative-button">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
