@using FribergCarRentals.Data.Customer
@model CustomerRegisterViewModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>
<div class="vertical-flex-container flex-container__align-items-center flex-container__row-gap__1-rem">
    <div class="horizontal-flex-container flex-container__justify-content__center flex-container__column-gap__0-5-rem">
        <button onclick="history.back()">Go Back</button>
        <a asp-action="List" class="button">View Customer List</a>        
    </div>
    <div class="horizontal-flex-container flex-container__justify-content__center filled-container flex-container__padding__1-rem">
        <form asp-action="Create" class="vertical-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="vertical-form-field">
                <label asp-for="FirstName"></label>
                <input asp-for="FirstName" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="vertical-form-field">
                <label asp-for="LastName"></label>
                <input asp-for="LastName" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
            <div class="vertical-form-field">
                <label asp-for="Email"></label>
                <input asp-for="Email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="vertical-form-field">
                <label asp-for="Password"></label>
                <input asp-for="Password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="vertical-form-field">
                <button type="submit">Create</button>
            </div>
        </form>
    </div>
</div>