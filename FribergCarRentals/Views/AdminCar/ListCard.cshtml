@model IEnumerable<CarViewModel>

@{
    ViewData["Title"] = "Index";
}

<h1>Cars</h1>
<div class="vertical-flex-container flex-container__row-gap__1-rem">
    <div class="horizontal-flex-container flex-container__justify-content__center flex-container__column-gap__0-5-rem">
        <a asp-action="Create">Create New Car</a>
        <div>|</div>
        <a asp-action="List">Table List</a>
    </div>
    @foreach (var item in Model) 
    {
        <div class="vertical-flex-container flex-container__filled-box flex-container__padding__1-rem">
            <h2>@($"{item.CarId} - {item.CarInfo}")</h2>
            <div class="horizontal-flex-container flex-container__justify-content__center flex-container__column-gap__0-5-rem">
                <a asp-action="Edit" asp-route-id="@item.CarId">Edit</a>
                <div>|</div>
                <a asp-action="Details" asp-route-id="@item.CarId">Details</a>
                <div>|</div>
                <a asp-action="Delete" asp-route-id="@item.CarId">Delete</a>
                <div>|</div>
                <button onclick="history.back()">Go Back</button>
            </div>
            <dl>
                <dt>
                    @Html.DisplayNameFor(model => model.CarId)
                </dt>
                <dd>
                    @Html.DisplayFor(model => item.CarId)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.Brand)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => item.Brand)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.Model)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => item.Model)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.ModelYear)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => item.ModelYear)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.Color)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => item.Color)
                </dd>        
                <dt>
                    @Html.DisplayNameFor(model => model.PropulsionSystem)
                </dt>
                <dd>
                    @item.PropulsionSystem.PropulsionName
                </dd>
           @*      <dt>
                    @Html.DisplayNameFor(model => model.RegistrationNumber)
                </dt>
                <dd>
                    @Html.DisplayFor(model => item.RegistrationNumber)
                </dd> *@
                <dt>
                    @Html.DisplayNameFor(model => model.RentalStatus)
                </dt>
                <dd>
                    @item.RentalStatus.StatusName
                </dd>            
              @*   <dt>
                    @Html.DisplayNameFor(model => item.ImageCount)
                </dt>
                <dd>
                    @Html.DisplayFor(model => item.ImageCount)
                </dd> *@
            </dl>
        </div>
    }
</div>
