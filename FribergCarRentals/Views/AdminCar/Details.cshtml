@using System.Web
@model CarViewModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>CarEntity</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Brand)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Brand)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Color)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Color)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Model)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Model)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ModelYear)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ModelYear)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.RegistrationNumber)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RegistrationNumber)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.RentalStatus)
        </dt>
        <dd class="col-sm-10">
            @Model.RentalStatus.StatusName
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PropulsionSystem)
        </dt>
        <dd class="col-sm-10">
            @Model.PropulsionSystem.PropulsionName
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ImageFilePaths)
        </dt>
        <dd class="col-sm-10">
            @foreach (var image in Model.Images)
            {
                <img src="@image.FilePath" />
                <div>@image.FilePath</div>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.CarId">Edit</a> |    
    @if (Model!.IsRequestFromAnotherController)
    {
        <a asp-action="List">View Car List</a>
        <span>| <button onclick="history.back()">Go Back</button></span>
    }
    else
    {
        <a asp-action="List">Back to Car List</a>
    }
</div>