@model CarBookingViewModel

@{
    ViewData["Title"] = "CancelBooking";
}

<h1>CancelBooking</h1>
<h2>Are you sure you want to cancel this?</h2>
<div>
    <h4>CarBookingEntity</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CarOrder.CarOrderId)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CarOrder.CarOrderId)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PickupDateString)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PickupDateString)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.RentalCostPerDay)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RentalCostPerDay)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ReturnDateString)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ReturnDateString)
        </dd>
    </dl>
    
    <form asp-action="Cancel">
        <input type="hidden" asp-for="CarBookingId" />
        <input type="submit" value="Cancel" class="btn btn-danger" /> |
        <a asp-action="ListFutureBookings">Back to List</a>
    </form>
</div>
