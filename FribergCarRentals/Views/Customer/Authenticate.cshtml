@using FribergCarRentals.Data.Customer
@model CustomerRegisterOrLoginViewModel

@{
    ViewData["Title"] = "Login";
}

<h1>Logged out</h1>
<p class="text-align-center">You must login to continue. If you don't have an account you can create one below.</p>

<div class="grid-container grid-container__columns-2">
    <div class="grid-container__column-1">
        <partial name="Register.cshtml" model="@Model.CustomerCreateViewModel" />
    </div>
    <div class="grid-container__column-2">
        <partial name="Login.cshtml" model="@Model.CustomerLoginViewModel" />
    </div>    
</div>