@using FribergCarRentals.Models.Order
@model OrderViewModel

@{
    ViewData["Title"] = "Order Details";
}

<h1>@($"Order - #{Model.CarOrderId}")</h1>
<h2>@($"{Model.Customer.FullName} - {Model.CarBooking.Car.CarInfo}")</h2>
<div class="vertical-flex-container flex-container__row-gap__1-rem">
    <div class="horizontal-flex-container flex-container__justify-content__center flex-container__column-gap__0-5-rem flex-container__row-gap__0-5-rem flex-container__wrap">
        <a asp-action="List" class="button navigational-button">View Orders</a>
        <a asp-action="Details" asp-controller="AdminCustomer" asp-route-id="@Model.Customer.UserId" class="button navigational-button">View customer</a>
        <a asp-action="Details" asp-controller="AdminCar" asp-route-id="@Model.CarBooking.Car.CarId" class="button navigational-button">View car</a>
        @if (Model.CanBeCompleted)
        {
            <form asp-action="Complete" onsubmit="return confirm('Are you sure you want to complete this order?');">
                <input type="hidden" name="id" value="@Model.CarOrderId" asp-for="@Model.CarOrderId" />
                <button type="submit" class="positive-button">Complete</button>
            </form>
        }
        <form asp-action="Delete" onsubmit="return confirm('Are you sure you want to delete this order?');">
            <input type="hidden" name="id" value="@Model.CarOrderId" asp-for="CarOrderId" />
            <button type="submit" class="negative-button full-height">Delete</button>
        </form>
    </div>
    <partial name="/Pages/Shared/_UserMessages.cshtml" for="Messages" />
    <div class="vertical-flex-container filled-container flex-container__padding__1-rem">
        <div class="vertical-flex-container flex-container__padding__1-rem">
            <h2>Order details</h2>
            <dl>
                <dt>
                    @Html.DisplayNameFor(model => model.CarOrderId)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.CarOrderId)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.OrderStatusName)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.OrderStatusName)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.OrderDateLocal)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.OrderDateLocal)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.CarBooking.CarPickupDate)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.CarBooking.CarPickupDate)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.CarBooking.CarReturnDate)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.CarBooking.CarReturnDate)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.CarBooking.DebitedRentalDays)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.CarBooking.DebitedRentalDays)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.CarBooking.RentalCostPerDay)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.CarBooking.RentalCostPerDay)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.OrderSum)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.OrderSum)
                </dd>
            </dl>
        </div>
        <div class="vertical-flex-container flex-container__padding__1-rem">
            <h2>Customer</h2>
            <dl>
                <dt>
                    @Html.DisplayNameFor(model => model.Customer.UserId)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.Customer.UserId)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.Customer.FullName)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.Customer.FullName)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.Customer.Email)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.Customer.Email)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.Customer.OrderCount)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.Customer.OrderCount)
                </dd>
            </dl>
        </div>
        <div class="vertical-flex-container flex-container__padding__1-rem">
            <h2>Booked Car</h2>
            <dl>
                <dt>
                    @Html.DisplayNameFor(model => model.CarBooking.Car.CarId)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.CarBooking.Car.CarId)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.CarBooking.Car.Brand)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.CarBooking.Car.Brand)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.CarBooking.Car.Model)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.CarBooking.Car.Model)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.CarBooking.Car.ModelYear)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.CarBooking.Car.ModelYear)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.CarBooking.Car.Color)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.CarBooking.Car.Color)
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.CarBooking.Car.PropulsionSystem)
                </dt>
                <dd>
                    @model.CarBooking.Car.PropulsionSystem.PropulsionName
                </dd>
                <dt>
                    @Html.DisplayNameFor(model => model.CarBooking.Car.RegistrationNumber)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.CarBooking.Car.RegistrationNumber)
                </dd>
            </dl>
            <div class="tiled-image-gallery">
                @foreach (var image in Model.CarBooking.Car.Images)
                {
                    <figure>
                        <div class="vertical-flex-container">
                            <img src="@image.Url" />
                        </div>
                    </figure>
                }
            </div>
        </div>
    </div>
</div>
